@{
    ViewData["Title"] = "Forgot Password Confirmation";
    var resetLink = TempData["ResetLink"] as string;
}

<div class="auth-wrapper">
    <div class="auth-card">
        <div class="auth-header">
            <h2>Check Your Email</h2>
            <p>If an account exists for that email, a reset link has been sent.</p>
        </div>

        <p class="text-center">Please check your inbox (and spam folder) for further instructions.</p>
        
        <div class="auth-footer">
            <p><a asp-action="Login" class="btn btn-primary">Back to Login</a></p>
        </div>
    </div>
</div>
