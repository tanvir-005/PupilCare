@model PupilCare.ViewModels.LoginViewModel

@{
    ViewData["Title"] = "Log in";
}

<div class="auth-wrapper">
    <div class="auth-card">
        <div class="auth-header">
            <h2>Sign In to PupilCare</h2>
            <p>Welcome back! Please enter your details.</p>
        </div>

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success">
                @TempData["SuccessMessage"]
            </div>
        }

        <form method="post" class="auth-form">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            
            <div class="form-group">
                <label asp-for="Email"></label>
                <input asp-for="Email" class="form-control" placeholder="admin@school.com" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>
            
            <div class="form-group">
                <label asp-for="Password"></label>
                <input asp-for="Password" class="form-control" placeholder="••••••••" />
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>
            
            <div class="form-group checkbox-group">
                <label>
                    <input asp-for="RememberMe" />
                    @Html.DisplayNameFor(m => m.RememberMe)
                </label>
            </div>
            
            <button type="submit" class="btn btn-primary btn-block">Log in</button>
        </form>
        
        <div class="auth-footer">
            <p>New School? <a asp-action="Register">Register here</a></p>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
