@model PupilCare.ViewModels.RegisterSchoolAdminViewModel

@{
    ViewData["Title"] = "Register School";
}

<div class="auth-wrapper">
    <div class="auth-card register-card">
        <div class="auth-header">
            <h2>Register Your School</h2>
            <p>Join PupilCare to manage your institution efficiently.</p>
        </div>

        <form method="post" class="auth-form">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            
            <div class="form-row">
                <div class="form-column">
                    <h4>Admin Details</h4>
                    <div class="form-group">
                        <label asp-for="FullName">Full Name</label>
                        <input asp-for="FullName" class="form-control" placeholder="John Doe" />
                        <span asp-validation-for="FullName" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="Email">Admin Email</label>
                        <input asp-for="Email" class="form-control" placeholder="admin@school.com" />
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="Password">Password</label>
                        <input asp-for="Password" class="form-control" placeholder="••••••••" />
                        <span asp-validation-for="Password" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="ConfirmPassword">Confirm Password</label>
                        <input asp-for="ConfirmPassword" class="form-control" placeholder="••••••••" />
                        <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                    </div>
                </div>

                <div class="form-column border-left">
                    <h4>School Details</h4>
                    <div class="form-group">
                        <label asp-for="SchoolName">School Name</label>
                        <input asp-for="SchoolName" class="form-control" placeholder="Springfield High" />
                        <span asp-validation-for="SchoolName" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="SchoolAddress">Address</label>
                        <input asp-for="SchoolAddress" class="form-control" placeholder="123 Education St" />
                        <span asp-validation-for="SchoolAddress" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="SchoolContact">Contact Number</label>
                        <input asp-for="SchoolContact" class="form-control" placeholder="+1 234 567 890" />
                        <span asp-validation-for="SchoolContact" class="text-danger"></span>
                    </div>
                </div>
            </div>

            <button type="submit" class="btn btn-primary btn-block mt-4">Submit Registration Application</button>
        </form>
        
        <div class="auth-footer">
            <p>Already registered? <a asp-action="Login">Log in here</a></p>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
