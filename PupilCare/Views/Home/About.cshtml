@{
    ViewData["Title"] = "About Us";
}

<div class="card my-4">
    <div class="card-header" style="background-color: var(--color-primary-lighter); padding: 1rem;">
        <h2 style="margin: 0; color: var(--color-primary-dark);">About PupilCare</h2>
    </div>
    <div class="card-body" style="padding: 1.5rem; border: 1px solid var(--color-border); border-top: none;">
        <p>PupilCare is a comprehensive decision support system built for modern educational institutions. We empower schools and teachers to manage classrooms and securely track academic and behavioral performances.</p>
        <p>Our goal is to foster an environment where nurturing potential and empowering minds is made easier with streamlined administration.</p>
    </div>
</div>
