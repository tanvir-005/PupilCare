@model PupilCare.Models.SystemSetting
@{
    ViewData["Title"] = "Career";
}

<div class="panel">
    <div class="panel-header">
        <h2 class="panel-title">Join Our Team</h2>
    </div>
    <div class="panel-body">
        <div class="content-text">
            @if (Model != null && !string.IsNullOrEmpty(Model.Careers))
            {
                <p>@Model.Careers</p>
            }
            else
            {
                <p>We are always looking for passionate individuals who want to make a difference in education technology. Join us in building the next generation of student management systems.</p>
                <div class="alert alert-info">
                    No open positions at the moment. Please check back later or send your CV to @(Model?.ContactEmail ?? "careers@pupilcare.com").
                </div>
            }
        </div>
    </div>
</div>

<style>
    .content-text { font-size: 1.1rem; line-height: 1.8; color: var(--text-dark); white-space: pre-wrap; }
</style>
