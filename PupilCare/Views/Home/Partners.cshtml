@model PupilCare.Models.SystemSetting
@{
    ViewData["Title"] = "Our Partners";
}

<div class="panel">
    <div class="panel-header">
        <h2 class="panel-title">@ViewData["Title"]</h2>
    </div>
    <div class="panel-body">
        <div class="content-text">
            @if (Model != null && !string.IsNullOrEmpty(Model.Partners))
            {
                <p>@Model.Partners</p>
            }
            else
            {
                <p>We work with leading schools, educational boards, and technology partners to provide a holistic ecosystem for student success.</p>
                <div class="partners-grid mt-4">
                    <p class="text-muted text-center">Collaborating with 50+ institutions across the country.</p>
                </div>
            }
        </div>
    </div>
</div>

<style>
    .content-text { font-size: 1.1rem; line-height: 1.8; color: var(--text-dark); white-space: pre-wrap; }
</style>
