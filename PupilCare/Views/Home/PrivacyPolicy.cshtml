@model PupilCare.Models.SystemSetting
@{
    ViewData["Title"] = "Privacy Policy";
}

<div class="panel">
    <div class="panel-header">
        <h2 class="panel-title">@ViewData["Title"]</h2>
    </div>
    <div class="panel-body">
        <div class="content-text">
            @if (Model != null && !string.IsNullOrEmpty(Model.PrivacyPolicy))
            {
                <p>@Model.PrivacyPolicy</p>
            }
            else
            {
                <p>Your privacy is important to us. This policy outlines how we collect, use, and protect your information when you use PupilCare.</p>
                <p>We are committed to ensuring that your data is secure and handled according to international standards.</p>
            }
        </div>
    </div>
</div>

<style>
    .content-text { font-size: 1.1rem; line-height: 1.8; color: var(--text-dark); white-space: pre-wrap; }
</style>
