@{
    ViewData["Title"] = "Privacy Policy";
}

<div class="card my-4">
    <div class="card-header" style="background-color: var(--color-primary-lighter); padding: 1rem;">
        <h2 style="margin: 0; color: var(--color-primary-dark);">Privacy Policy</h2>
    </div>
    <div class="card-body" style="padding: 1.5rem; border: 1px solid var(--color-border); border-top: none;">
        <p>At PupilCare, your data privacy is paramount. We do not sell data to third-party ad networks.</p>
        <p>Student names, identifiers, and performance metrics are strictly siloed and encrypted at rest using AES-256 standards.</p>
    </div>
</div>
