@{
    ViewData["Title"] = "Services";
}

<div class="card my-4">
    <div class="card-header" style="background-color: var(--color-primary-lighter); padding: 1rem;">
        <h2 style="margin: 0; color: var(--color-primary-dark);">Our Services</h2>
    </div>
    <div class="card-body" style="padding: 1.5rem; border: 1px solid var(--color-border); border-top: none;">
        <ul>
            <li><strong>School Management Database:</strong> Store complete details about classrooms and operations.</li>
            <li><strong>Teachers' Hub:</strong> Fast role assignments and access.</li>
            <li><strong>Student Tracking Engine:</strong> Robust record-keeping for behaviors and academic marks.</li>
            <li><strong>AI Insights Module:</strong> Export records into pure text contexts for data analysis safely.</li>
        </ul>
    </div>
</div>
