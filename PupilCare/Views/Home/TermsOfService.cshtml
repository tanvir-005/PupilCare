@model PupilCare.Models.SystemSetting
@{
    ViewData["Title"] = "Terms of Service";
}

<div class="panel">
    <div class="panel-header">
        <h2 class="panel-title">@ViewData["Title"]</h2>
    </div>
    <div class="panel-body">
        <div class="content-text">
            @if (Model != null && !string.IsNullOrEmpty(Model.TermsAndConditions))
            {
                <p>@Model.TermsAndConditions</p>
            }
            else
            {
                <p>By using PupilCare, you agree to the following terms and conditions. These terms govern your use of our platform and services.</p>
                <p>Please read them carefully before proceeding.</p>
            }
        </div>
    </div>
</div>

<style>
    .content-text { font-size: 1.1rem; line-height: 1.8; color: var(--text-dark); white-space: pre-wrap; }
</style>
