@{
    ViewData["Title"] = "Terms of Service";
}

<div class="card my-4">
    <div class="card-header" style="background-color: var(--color-primary-lighter); padding: 1rem;">
        <h2 style="margin: 0; color: var(--color-primary-dark);">Terms of Service</h2>
    </div>
    <div class="card-body" style="padding: 1.5rem; border: 1px solid var(--color-border); border-top: none;">
        <p>By using PupilCare, schools agree to maintain ethical standards when evaluating student records.</p>
        <p>Schools bear the responsibility of authenticating teachers and avoiding unauthorized data disclosures.</p>
        <p>We reserve the right to suspend any super-admin access for policy violations.</p>
    </div>
</div>
