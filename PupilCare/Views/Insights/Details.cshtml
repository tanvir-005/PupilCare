@model PupilCare.Models.AiInsight
@{
    ViewData["Title"] = "Insight Details";
}

<div class="dashboard-container">
    <div class="dashboard-header split-header">
        <div>
            <h2>@Model.ScopeLabel</h2>
            <p class="text-muted">@Model.InsightScope - generated by @Model.GeneratedBy.FullName at @Model.GeneratedAt.ToLocalTime()</p>
        </div>
        <a asp-action="Index" class="btn btn-secondary">Back</a>
    </div>

    <div class="panel">
        <div class="panel-header"><h5 class="panel-title">Insight</h5></div>
        <div class="panel-body">
            <pre style="white-space: pre-wrap; font-family: inherit;">@Model.GeneratedText</pre>
        </div>
    </div>
</div>
