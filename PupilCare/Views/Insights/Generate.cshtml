@model PupilCare.ViewModels.GenerateInsightViewModel
@{
    ViewData["Title"] = "Generate Insight";
}

<div class="panel form-panel">
    <div class="panel-header"><h2 class="panel-title">Generate Insight</h2></div>
    <div class="panel-body">
        <form asp-action="Generate" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="InsightScope">Scope</label>
                <select asp-for="InsightScope" class="form-control">
                    <option value="Student">One student</option>
                    <option value="SectionSubject">Section and subject</option>
                    <option value="ClassSubject">Class and subject</option>
                    <option value="Section">Section, all subjects</option>
                    <option value="Class">Class, all sections and subjects</option>
                    <option value="School">Entire school</option>
                </select>
            </div>
            <div class="form-group">
                <label asp-for="StudentId">Student</label>
                <select asp-for="StudentId" asp-items="ViewBag.Students" class="form-control"><option value="">Not selected</option></select>
            </div>
            <div class="form-group">
                <label asp-for="ClassLevelId">Class</label>
                <select asp-for="ClassLevelId" asp-items="ViewBag.Classes" class="form-control"><option value="">Not selected</option></select>
            </div>
            <div class="form-group">
                <label asp-for="ClassSectionId">Section</label>
                <select asp-for="ClassSectionId" asp-items="ViewBag.Sections" class="form-control"><option value="">Not selected</option></select>
            </div>
            <div class="form-group">
                <label asp-for="SubjectId">Subject</label>
                <select asp-for="SubjectId" asp-items="ViewBag.Subjects" class="form-control"><option value="">Not selected</option></select>
            </div>
            <div class="form-actions">
                <a asp-action="Index" class="btn btn-secondary">Cancel</a>
                <button type="submit" class="btn btn-primary">Generate</button>
            </div>
        </form>
    </div>
</div>
