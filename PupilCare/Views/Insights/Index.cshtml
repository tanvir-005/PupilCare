@model IEnumerable<PupilCare.Models.AiInsight>
@{
    ViewData["Title"] = "AI Insights";
}

<div class="dashboard-container">
    <div class="dashboard-header split-header">
        <h2>AI Insights</h2>
        <a asp-action="Generate" class="btn btn-primary">Generate Insight</a>
    </div>

    <div class="panel">
        <div class="panel-header"><h5 class="panel-title">Generated Insights</h5></div>
        <div class="panel-body-nopad">
            <table class="data-table">
                <thead><tr><th>Scope</th><th>Label</th><th>Generated By</th><th>Generated At</th><th></th></tr></thead>
                <tbody>
                @foreach (var insight in Model)
                {
                    <tr>
                        <td>@insight.InsightScope</td>
                        <td>@insight.ScopeLabel</td>
                        <td>@insight.GeneratedBy.FullName</td>
                        <td>@insight.GeneratedAt.ToLocalTime()</td>
                        <td class="text-right"><a asp-action="Details" asp-route-id="@insight.Id" class="btn btn-secondary">Open</a></td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>
