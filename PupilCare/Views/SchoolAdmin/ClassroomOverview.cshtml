@model PupilCare.Models.Classroom

@{
    ViewData["Title"] = $"Overview - {Model.Name}";
}

<div class="dashboard-header" style="margin-bottom: 2rem; display: flex; justify-content: space-between; align-items: flex-end;">
    <div>
        <h2>@Model.Name Overview</h2>
        <p>Grade Level: @Model.GradeLevel | Total Students: @Model.Students.Count</p>
    </div>
    <div style="display: flex; gap: 1rem;">
        <a asp-action="ExportClassJson" asp-route-id="@Model.Id" class="btn btn-primary" target="_blank" style="padding: 0.5rem 1rem;">Export Class JSON</a>
        <a asp-action="Dashboard" class="btn btn-secondary" style="padding: 0.5rem 1rem;">&larr; Back to Dashboard</a>
    </div>
</div>

<div class="card my-4">
    <div class="card-header" style="background-color: var(--color-primary-lighter); padding: 1rem;">
        <h4 style="margin: 0; color: var(--color-primary-dark);">Enrolled Students & Records</h4>
    </div>
    <div class="card-body" style="padding: 1.5rem; border: 1px solid var(--color-primary-lighter); border-top: none;">
        @if (!Model.Students.Any())
        {
            <p class="text-muted">No students enrolled in this classroom.</p>
        }
        else
        {
            <table class="table" style="width: 100%; border-collapse: collapse;">
                <thead>
                    <tr style="border-bottom: 2px solid var(--color-border); text-align: left;">
                        <th style="padding: 0.75rem;">Student Info</th>
                        <th style="padding: 0.75rem;">Details</th>
                        <th style="padding: 0.75rem;">Records</th>
                        <th style="padding: 0.75rem; text-align: right;">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var student in Model.Students.OrderBy(s => s.Name))
                    {
                        <tr style="border-bottom: 1px solid var(--color-border);">
                            <td style="padding: 0.75rem;">
                                <strong>@student.Name</strong>
                                <span style="font-size: 0.85rem; color: var(--color-text-muted); display: block;">ID: @student.StudentId</span>
                            </td>
                            <td style="padding: 0.75rem;">
                                <div style="font-size: 0.85rem;">@student.Gender | @student.DateOfBirth.ToShortDateString()</div>
                                <div style="font-size: 0.85rem; color: var(--color-text-muted);">@student.Contact | @student.Address</div>
                            </td>
                            <td style="padding: 0.75rem;">
                                <button class="btn btn-sm btn-outline-primary" style="font-size: 0.8rem;" onclick="document.getElementById('records_@student.Id').style.display = document.getElementById('records_@student.Id').style.display === 'none' ? 'table-row' : 'none'">
                                    Toggle @(student.Records?.Count ?? 0) Records
                                </button>
                            </td>
                            <td style="padding: 0.75rem; text-align: right; display: flex; gap: 0.5rem; justify-content: flex-end;">
                                <a asp-action="ExportStudentJson" asp-route-id="@student.Id" class="btn btn-outline-info btn-sm" target="_blank" style="font-size: 0.8rem; padding: 0.2rem 0.5rem; text-decoration: none;">Export JSON</a>
                                <button type="button" class="btn btn-outline-primary btn-sm" style="font-size: 0.8rem;" onclick="document.getElementById('editStudent_@student.Id').style.display='table-row'">Edit</button>
                                <form method="post" asp-action="DeleteStudent" asp-route-id="@student.Id" onsubmit="return confirm('Delete this student?');">
                                    <button type="submit" class="btn btn-outline-danger btn-sm" style="font-size: 0.8rem;">Delete</button>
                                </form>
                            </td>
                        </tr>
                        
                        <!-- Edit Student Row -->
                        <tr id="editStudent_@student.Id" style="display:none; background-color: #fafBfb;">
                            <td colspan="4" style="padding: 1rem; border-bottom: 1px solid var(--color-border);">
                                <form method="post" asp-action="EditStudent" style="display: flex; gap: 1rem; flex-wrap: wrap; align-items: end;">
                                    <input type="hidden" name="id" value="@student.Id" />
                                    <div class="form-group" style="flex: 1; min-width: 150px;">
                                        <label style="font-size: 0.8rem;">Name</label>
                                        <input name="name" class="form-control" required value="@student.Name" style="font-size: 0.85rem;" />
                                    </div>
                                    <div class="form-group" style="flex: 1; min-width: 100px;">
                                        <label style="font-size: 0.8rem;">Gender</label>
                                        <input name="gender" class="form-control" required value="@student.Gender" style="font-size: 0.85rem;" />
                                    </div>
                                    <div class="form-group" style="flex: 1; min-width: 150px;">
                                        <label style="font-size: 0.8rem;">Contact</label>
                                        <input name="contact" class="form-control" value="@student.Contact" style="font-size: 0.85rem;" />
                                    </div>
                                    <div class="form-group" style="flex: 2; min-width: 200px;">
                                        <label style="font-size: 0.8rem;">Address</label>
                                        <input name="address" class="form-control" value="@student.Address" style="font-size: 0.85rem;" />
                                    </div>
                                    <div style="display: flex; gap: 0.5rem; margin-bottom: 1rem;">
                                        <button type="submit" class="btn btn-primary btn-sm">Save</button>
                                        <button type="button" class="btn btn-secondary btn-sm" onclick="document.getElementById('editStudent_@student.Id').style.display='none'">Cancel</button>
                                    </div>
                                </form>
                            </td>
                        </tr>

                        <!-- Records Row -->
                        <tr id="records_@student.Id" style="display:none; background-color: #f4f6f8;">
                            <td colspan="4" style="padding: 1rem 2rem; border-bottom: 1px solid var(--color-border);">
                                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem;">
                                    <h6 style="color: var(--color-primary-dark); margin: 0;">Behavioral & Academic Records</h6>
                                    <button class="btn btn-sm btn-success" onclick="document.getElementById('addRecord_@student.Id').style.display='block'">+ Add Record</button>
                                </div>
                                
                                <div id="addRecord_@student.Id" style="display:none; background: white; padding: 1rem; border: 1px solid var(--color-border); margin-bottom: 1rem;">
                                    <form method="post" asp-action="AddRecord">
                                        <input type="hidden" name="StudentId" value="@student.Id" />
                                        <input type="hidden" name="returnUrl" value="@Context.Request.Path" />
                                        <div class="form-group">
                                            <select name="Type" class="form-control" required style="font-size: 0.85rem; margin-bottom: 0.5rem;">
                                                <option value="">Select Type...</option>
                                                <option value="Academic">Academic</option>
                                                <option value="Behavioral">Behavioral</option>
                                                <option value="Attendance">Attendance</option>
                                                <option value="Other">Other</option>
                                            </select>
                                        </div>
                                        <div class="form-group">
                                            <textarea name="Text" class="form-control" rows="2" required placeholder="Details..." style="font-size: 0.85rem; margin-bottom: 0.5rem;"></textarea>
                                        </div>
                                        <button type="submit" class="btn btn-success btn-sm">Save Record</button>
                                        <button type="button" class="btn btn-secondary btn-sm" onclick="document.getElementById('addRecord_@student.Id').style.display='none'">Cancel</button>
                                    </form>
                                </div>

                                @if (student.Records != null && student.Records.Any())
                                {
                                    <ul style="list-style: none; padding: 0;">
                                        @foreach(var r in student.Records.OrderByDescending(rec => rec.CreatedAt))
                                        {
                                            <li style="background: white; padding: 0.8rem; border: 1px solid var(--color-border); margin-bottom: 0.5rem; border-radius: 4px;">
                                                <div style="display: flex; justify-content: space-between; margin-bottom: 0.5rem;">
                                                    <div>
                                                        <span style="font-size: 0.8rem; font-weight: 600; padding: 0.2rem 0.5rem; background-color: var(--color-primary-lighter); color: var(--color-primary-dark);">@r.Type</span>
                                                        <span style="font-size: 0.8rem; color: var(--color-text-muted); margin-left: 0.5rem;">@r.CreatedAt.ToShortDateString()</span>
                                                    </div>
                                                    <div style="display: flex; gap: 0.5rem;">
                                                        <button class="btn btn-sm btn-outline-primary" style="font-size: 0.7rem; padding: 0.1rem 0.4rem;" onclick="document.getElementById('editRecord_@r.Id').style.display='block'">Edit</button>
                                                        <form method="post" asp-action="DeleteRecord" asp-route-id="@r.Id" onsubmit="return confirm('Delete this record?');">
                                                            <input type="hidden" name="returnUrl" value="@Context.Request.Path" />
                                                            <button type="submit" class="btn btn-sm btn-outline-danger" style="font-size: 0.7rem; padding: 0.1rem 0.4rem;">Del</button>
                                                        </form>
                                                    </div>
                                                </div>
                                                <div style="font-size: 0.9rem; font-style: italic;">"@r.Text"</div>
                                                
                                                <div id="editRecord_@r.Id" style="display:none; margin-top: 1rem; border-top: 1px dashed var(--color-border); padding-top: 1rem;">
                                                    <form method="post" asp-action="EditRecord">
                                                        <input type="hidden" name="id" value="@r.Id" />
                                                        <input type="hidden" name="returnUrl" value="@Context.Request.Path" />
                                                        <div class="form-group">
                                                            <select name="Type" class="form-control" required style="font-size: 0.85rem; margin-bottom: 0.5rem;">
                                                                <option value="Academic" selected="@(r.Type=="Academic")">Academic</option>
                                                                <option value="Behavioral" selected="@(r.Type=="Behavioral")">Behavioral</option>
                                                                <option value="Attendance" selected="@(r.Type=="Attendance")">Attendance</option>
                                                                <option value="Other" selected="@(r.Type=="Other")">Other</option>
                                                            </select>
                                                        </div>
                                                        <div class="form-group">
                                                            <textarea name="Text" class="form-control" rows="2" required style="font-size: 0.85rem; margin-bottom: 0.5rem;">@r.Text</textarea>
                                                        </div>
                                                        <button type="submit" class="btn btn-primary btn-sm">Update</button>
                                                        <button type="button" class="btn btn-secondary btn-sm" onclick="document.getElementById('editRecord_@r.Id').style.display='none'">Cancel</button>
                                                    </form>
                                                </div>
                                            </li>
                                        }
                                    </ul>
                                }
                                else
                                {
                                    <p class="text-muted" style="font-size: 0.9rem;">No records exist for this student.</p>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>
