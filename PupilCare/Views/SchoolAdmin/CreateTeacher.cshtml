@model PupilCare.ViewModels.CreateTeacherViewModel
@{
    ViewData["Title"] = "Create Teacher";
}

<div class="panel form-panel">
    <div class="panel-header"><h2 class="panel-title">Create Teacher</h2></div>
    <div class="panel-body">
        <form asp-action="CreateTeacher" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group"><label asp-for="FullName"></label><input asp-for="FullName" class="form-control" /><span asp-validation-for="FullName" class="text-danger"></span></div>
            <div class="form-group"><label asp-for="Email"></label><input asp-for="Email" class="form-control" /><span asp-validation-for="Email" class="text-danger"></span></div>
            <div class="form-group"><label asp-for="Password"></label><input asp-for="Password" class="form-control" /><span asp-validation-for="Password" class="text-danger"></span></div>
            <div class="form-group"><label asp-for="Phone"></label><input asp-for="Phone" class="form-control" /></div>
            <div class="form-group"><label asp-for="Designation"></label><input asp-for="Designation" class="form-control" /></div>
            <div class="form-actions"><a asp-action="Teachers" class="btn btn-secondary">Cancel</a><button class="btn btn-primary" type="submit">Create</button></div>
        </form>
    </div>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
