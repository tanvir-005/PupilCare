@using PupilCare.ViewModels
@model PupilCare.Models.School

@{
    ViewData["Title"] = "School Admin Dashboard";
    var teachers = ViewBag.Teachers as List<PupilCare.Models.ApplicationUser>;
}

<div class="dashboard-header" style="margin-bottom: 2rem;">
    <h2>@Model.Name - Admin Dashboard</h2>
    <p>Manage your classrooms, teachers, and students.</p>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success" style="padding: 1rem; background-color: var(--color-success); color: white; margin-bottom: 1.5rem;">
        @TempData["SuccessMessage"]
    </div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger" style="padding: 1rem; background-color: var(--color-danger); color: white; margin-bottom: 1.5rem;">
        @TempData["ErrorMessage"]
    </div>
}

<div class="form-row" style="grid-template-columns: 1fr; gap: 2rem;">
    <!-- Classrooms & Students List -->
    <div class="card">
        <div class="card-header" style="background-color: var(--color-primary-lighter); padding: 1rem; display: flex; justify-content: space-between; align-items: center;">
            <h4 style="margin: 0; color: var(--color-primary-dark);">Classrooms</h4>
            <button type="button" class="btn btn-primary" style="padding: 0.4rem 0.8rem;" onclick="document.getElementById('createClassroomForm').style.display='block'">+ New Classroom</button>
        </div>
        
        <div id="createClassroomForm" style="display:none; padding: 1.5rem; background-color: white; border: 1px solid var(--color-border); border-top: none;">
            <form method="post" asp-action="CreateClassroom">
                <div class="form-group">
                    <label>Classroom Name</label>
                    <input name="Name" class="form-control" required placeholder="Geometry 101" />
                </div>
                <div class="form-group">
                    <label>Grade Level</label>
                    <input name="GradeLevel" class="form-control" required placeholder="10th Grade" />
                </div>
                <button type="submit" class="btn btn-success">Save Classroom</button>
                <button type="button" class="btn btn-secondary" onclick="document.getElementById('createClassroomForm').style.display='none'">Cancel</button>
            </form>
        </div>

        <div class="card-body" style="padding: 1.5rem; border: 1px solid var(--color-border); border-top: none;">
            @if (!Model.Classrooms.Any())
            {
                <p class="text-muted">No classrooms created yet.</p>
            }
            else
            {
                <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 1.5rem;">
                    @foreach (var c in Model.Classrooms)
                    {
                        <div style="border: 1px solid var(--color-border); padding: 1rem;">
                            <h5 style="color: var(--color-primary); margin-bottom: 0.2rem;">@c.Name</h5>
                            <p style="font-size: 0.85rem; color: var(--color-text-muted); margin-bottom: 1rem;">Grade: @c.GradeLevel | Students: @c.Students.Count</p>
                            
                            <hr style="border: 0; border-top: 1px solid var(--color-border); margin-bottom: 1rem;"/>
                            <h6 style="font-size: 0.9rem; margin-bottom: 0.5rem;">Students</h6>
                            <ul style="list-style: none; padding-left: 0; font-size: 0.85rem; margin-bottom: 1rem;">
                                @if(c.Students != null && c.Students.Any())
                                {
                                    @foreach(var s in c.Students.Take(5))
                                    {
                                        <li>@s.Name (@s.Gender)</li>
                                    }
                                    @if(c.Students.Count > 5)
                                    {
                                        <li class="text-muted">...and @(c.Students.Count - 5) more.</li>
                                    }
                                }
                                else
                                {
                                    <li class="text-muted">No students enrolled yet.</li>
                                }
                            </ul>

                            <div style="display: flex; gap: 0.5rem; margin-top: 1rem;">
                                <a asp-action="ClassroomOverview" asp-route-id="@c.Id" class="btn btn-primary" style="font-size: 0.8rem; padding: 0.4rem; flex: 1; text-align: center;">Overview</a>
                                <button type="button" class="btn btn-secondary" style="font-size: 0.8rem; padding: 0.4rem; flex: 1;" onclick="document.getElementById('enrollStudentForm_@c.Id').style.display='block'">+ Enroll</button>
                            </div>
                            
                            <div id="enrollStudentForm_@c.Id" style="display:none; margin-top: 1rem; border-top: 1px solid var(--color-border); padding-top: 1rem;">
                                <form method="post" asp-action="EnrollStudent">
                                    <input type="hidden" name="ClassroomId" value="@c.Id" />
                                    <div class="form-group">
                                        <label style="font-size: 0.85rem;">Student Name *</label>
                                        <input name="Name" class="form-control" required placeholder="Student Name" style="font-size: 0.85rem;" />
                                    </div>
                                    <div class="form-group">
                                        <label style="font-size: 0.85rem;">Gender *</label>
                                        <input name="Gender" class="form-control" required placeholder="e.g. Male, Female" style="font-size: 0.85rem;"/>
                                    </div>
                                    <div class="form-group">
                                        <label style="font-size: 0.85rem;">Date of Birth *</label>
                                        <input type="date" name="DateOfBirth" class="form-control" required style="font-size: 0.85rem;"/>
                                    </div>
                                    <div class="form-group">
                                        <label style="font-size: 0.85rem;">Address</label>
                                        <input name="Address" class="form-control" placeholder="Address (Optional)" style="font-size: 0.85rem;" />
                                    </div>
                                    <div class="form-group">
                                        <label style="font-size: 0.85rem;">Contact</label>
                                        <input name="Contact" class="form-control" placeholder="Contact (Optional)" style="font-size: 0.85rem;" />
                                    </div>
                                    <button type="submit" class="btn btn-primary" style="font-size: 0.8rem; padding: 0.3rem 0.6rem;">Save</button>
                                    <button type="button" class="btn btn-secondary" style="font-size: 0.8rem; padding: 0.3rem 0.6rem;" onclick="document.getElementById('enrollStudentForm_@c.Id').style.display='none'">Cancel</button>
                                </form>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>

    <!-- Teachers List -->
    <div class="card mt-4">
        <div class="card-header" style="background-color: var(--color-primary-lighter); padding: 1rem; display: flex; justify-content: space-between; align-items: center;">
            <h4 style="margin: 0; color: var(--color-primary-dark);">Teachers</h4>
            <button type="button" class="btn btn-primary" style="padding: 0.4rem 0.8rem;" onclick="document.getElementById('createTeacherForm').style.display='block'">+ Add Teacher</button>
        </div>

        <div id="createTeacherForm" style="display:none; padding: 1.5rem; background-color: white; border: 1px solid var(--color-border); border-top: none;">
            <form method="post" asp-action="CreateTeacher">
                <div class="form-row">
                    <div class="form-group">
                        <label>Full Name</label>
                        <input name="FullName" class="form-control" required placeholder="Jane Smith" />
                    </div>
                    <div class="form-group">
                        <label>Login Email</label>
                        <input name="Email" type="email" class="form-control" required placeholder="teacher@school.com" />
                    </div>
                    <div class="form-group">
                        <label>Initial Password</label>
                        <input name="Password" type="password" class="form-control" required placeholder="••••••••" />
                    </div>
                </div>
                <button type="submit" class="btn btn-success">Create Account</button>
                <button type="button" class="btn btn-secondary" onclick="document.getElementById('createTeacherForm').style.display='none'">Cancel</button>
            </form>
        </div>

        <div class="card-body" style="padding: 1.5rem; border: 1px solid var(--color-border); border-top: none;">
            @if (teachers == null || !teachers.Any())
            {
                <p class="text-muted">No teachers registered yet.</p>
            }
            else
            {
                <table class="table" style="width: 100%; border-collapse: collapse;">
                    <thead>
                        <tr style="border-bottom: 2px solid var(--color-border); text-align: left;">
                            <th style="padding: 0.75rem;">Name</th>
                            <th style="padding: 0.75rem;">Email</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var t in teachers)
                        {
                            <tr style="border-bottom: 1px solid var(--color-border);">
                                <td style="padding: 0.75rem;"><strong>@t.FullName</strong></td>
                                <td style="padding: 0.75rem;">@t.Email</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>
</div>
