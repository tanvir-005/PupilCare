@model PupilCare.Models.School
@{
    ViewData["Title"] = "School Admin Dashboard";
}

<div class="dashboard-container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Dashboard - @Model.Name</h2>
        <div>
            @if (Model.SubscriptionExpiry.HasValue)
            {
                var daysLeft = (Model.SubscriptionExpiry.Value - DateTime.UtcNow).Days;
                if (daysLeft > 0)
                {
                    <span class="badge bg-success p-2">Subscription Active (@daysLeft days left)</span>
                }
                else
                {
                    <span class="badge bg-danger p-2">Subscription Expired</span>
                }
            }
            else
            {
                <span class="badge bg-secondary p-2">No Subscription</span>
            }
            <a asp-action="Subscription" class="btn btn-sm btn-outline-primary ms-2">Manage</a>
        </div>
    </div>

    <div class="row">
        <div class="col-md-3 mb-4">
            <div class="card stat-card shadow-sm border-0 text-center">
                <div class="card-body">
                    <h5 class="text-muted">Total Classes</h5>
                    <h2 class="fw-bold text-primary">@Model.ClassLevels.Count</h2>
                    <a asp-action="Classes" class="stretched-link text-decoration-none">View Details</a>
                </div>
            </div>
        </div>
        <div class="col-md-3 mb-4">
            <div class="card stat-card shadow-sm border-0 text-center">
                <div class="card-body">
                    <h5 class="text-muted">Students</h5>
                    <h2 class="fw-bold text-success">@ViewBag.Students</h2>
                    <a asp-action="Students" class="stretched-link text-decoration-none">Manage Students</a>
                </div>
            </div>
        </div>
        <div class="col-md-3 mb-4">
            <div class="card stat-card shadow-sm border-0 text-center">
                <div class="card-body">
                    <h5 class="text-muted">Teachers</h5>
                    <h2 class="fw-bold text-success">@ViewBag.Teachers?.Count</h2>
                    <a asp-action="Teachers" class="stretched-link text-decoration-none">Manage Teachers</a>
                </div>
            </div>
        </div>
        <div class="col-md-3 mb-4">
            <div class="card stat-card shadow-sm border-0 text-center">
                <div class="card-body">
                    <h5 class="text-muted">Exams</h5>
                    <h2 class="fw-bold text-primary">+</h2>
                    <a asp-action="Exams" class="stretched-link text-decoration-none">Manage Exams</a>
                </div>
            </div>
        </div>
        <div class="col-md-3 mb-4">
            <div class="card stat-card shadow-sm border-0 text-center">
                <div class="card-body">
                    <h5 class="text-muted">AI Insights</h5>
                    <h2 class="fw-bold text-primary">AI</h2>
                    <a asp-controller="Insights" asp-action="Index" class="stretched-link text-decoration-none">Open Insights</a>
                </div>
            </div>
        </div>
    </div>
</div>
