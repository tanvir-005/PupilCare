@model PupilCare.Models.School
@{
    ViewData["Title"] = "School Admin Dashboard";
}

<div class="dashboard-container">
    <div class="dashboard-header split-header">
        <h2>Dashboard - @Model.Name</h2>
        <div>
            @if (Model.SubscriptionExpiry.HasValue)
            {
                var daysLeft = (Model.SubscriptionExpiry.Value - DateTime.UtcNow).Days;
                if (daysLeft > 0)
                {
                    <span class="status-badge status-approved">Subscription Active (@daysLeft days left)</span>
                }
                else
                {
                    <span class="status-badge status-rejected">Subscription Expired</span>
                }
            }
            else
            {
                <span class="status-badge status-pending">No Subscription</span>
            }
        </div>
    </div>

    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 1.5rem; margin-top: 1.5rem;">
        <div class="stat-card text-center" style="padding: 0; display: flex; flex-direction: column;">
            <div class="card-body" style="padding: 1.5rem; flex: 1;">
                <h5 class="text-muted" style="margin-bottom: 0.5rem;">Total Classes</h5>
                <h2 class="fw-bold text-primary" style="margin-bottom: 0;">@Model.ClassLevels.Count</h2>
            </div>
            <a asp-action="Classes" class="stat-bottom-btn text-decoration-none">Manage Classes</a>
        </div>
        <div class="stat-card text-center" style="padding: 0; display: flex; flex-direction: column;">
            <div class="card-body" style="padding: 1.5rem; flex: 1;">
                <h5 class="text-muted" style="margin-bottom: 0.5rem;">Students</h5>
                <h2 class="fw-bold text-success" style="margin-bottom: 0;">@ViewBag.Students</h2>
            </div>
            <a asp-action="Students" class="stat-bottom-btn text-decoration-none">Manage Students</a>
        </div>
        <div class="stat-card text-center" style="padding: 0; display: flex; flex-direction: column;">
            <div class="card-body" style="padding: 1.5rem; flex: 1;">
                <h5 class="text-muted" style="margin-bottom: 0.5rem;">Teachers</h5>
                <h2 class="fw-bold text-success" style="margin-bottom: 0;">@ViewBag.Teachers?.Count</h2>
            </div>
            <a asp-action="Teachers" class="stat-bottom-btn text-decoration-none">Manage Teachers</a>
        </div>
        <div class="stat-card text-center" style="padding: 0; display: flex; flex-direction: column;">
            <div class="card-body" style="padding: 1.5rem; flex: 1;">
                <h5 class="text-muted" style="margin-bottom: 0.5rem;">Exams</h5>
                <h2 class="fw-bold text-primary" style="margin-bottom: 0;">@ViewBag.Exams</h2>
            </div>
            <a asp-action="Exams" class="stat-bottom-btn text-decoration-none">Manage Exams</a>
        </div>
        <div class="stat-card text-center" style="padding: 0; display: flex; flex-direction: column;">
            <div class="card-body" style="padding: 1.5rem; flex: 1;">
                <h5 class="text-muted" style="margin-bottom: 0.5rem;">AI Insights</h5>
                <h2 class="fw-bold text-primary" style="margin-bottom: 0;">Analyze</h2>
            </div>
            <a asp-controller="Insights" asp-action="Index" class="stat-bottom-btn text-decoration-none">Open Insights</a>
        </div>
        <div class="stat-card text-center" style="padding: 0; display: flex; flex-direction: column;">
            <div class="card-body" style="padding: 1.5rem; flex: 1;">
                <h5 class="text-muted" style="margin-bottom: 0.5rem;">Subscription</h5>
                @if (Model.SubscriptionExpiry.HasValue && Model.SubscriptionExpiry.Value > DateTime.UtcNow)
                {
                    <h2 class="fw-bold text-success" style="margin-bottom: 0;">@((Model.SubscriptionExpiry.Value - DateTime.UtcNow).Days) Days</h2>
                }
                else
                {
                    <h2 class="fw-bold text-danger" style="margin-bottom: 0;">Expired</h2>
                }
            </div>
            <a asp-action="Subscription" class="stat-bottom-btn text-decoration-none">Manage Plan</a>
        </div>
    </div>
</div>
