@model IEnumerable<PupilCare.Models.Exam>
@{
    ViewData["Title"] = "Exams";
}

<div class="dashboard-container">
    <div class="dashboard-header"><h2>Exams</h2></div>
    <div class="panel">
        <div class="panel-header"><h5 class="panel-title">Create Exam</h5></div>
        <div class="panel-body">
            <form asp-action="CreateExam" method="post" class="inline-form">
                <input name="Name" class="form-control w-auto" placeholder="Exam name" required />
                <input name="FullMark" type="number" class="form-control w-auto" placeholder="Full mark" required />
                <select name="ClassLevelId" asp-items="ViewBag.ClassLevels" class="form-control w-auto"></select>
                <button class="btn btn-primary" type="submit">Create</button>
            </form>
        </div>
    </div>
    <div class="panel">
        <div class="panel-header"><h5 class="panel-title">All Exams</h5></div>
        <div class="panel-body-nopad">
            <table class="data-table"><thead><tr><th>Name</th><th>Class</th><th>Full Mark</th></tr></thead><tbody>
            @foreach (var exam in Model)
            {
                <tr><td>@exam.Name</td><td>@exam.ClassLevel.Name</td><td>@exam.FullMark</td></tr>
            }
            </tbody></table>
        </div>
    </div>
</div>
