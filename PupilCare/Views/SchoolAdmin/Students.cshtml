@model IEnumerable<PupilCare.Models.Student>
@{
    ViewData["Title"] = "Students";
    var classes = ViewBag.Classes as List<PupilCare.Models.ClassLevel> ?? new();
}

<div class="dashboard-container">
    <div class="dashboard-header split-header">
        <h2>Students</h2>
        <a asp-action="EnrollStudent" class="btn btn-primary">Enroll Student</a>
    </div>

    <div class="panel">
        <div class="panel-header"><h5 class="panel-title">Filters and Promotion</h5></div>
        <div class="panel-body">
            <form asp-action="Students" method="get" class="inline-form">
                <select name="classLevelId" class="form-control w-auto">
                    <option value="">All classes</option>
                    @foreach (var cls in classes) { <option value="@cls.Id">@cls.Name</option> }
                </select>
                <select name="sectionId" class="form-control w-auto">
                    <option value="">All sections</option>
                    @foreach (var cls in classes)
                    {
                        foreach (var sec in cls.Sections.OrderBy(s => s.Name))
                        {
                            <option value="@sec.Id">@cls.Name - @sec.Name</option>
                        }
                    }
                </select>
                <button class="btn btn-secondary" type="submit">Apply</button>
            </form>
        </div>
    </div>

    <form asp-action="PromoteStudents" method="post">
        <div class="panel">
            <div class="panel-header">
                <h5 class="panel-title">Student List</h5>
                <div class="panel-actions">
                    <select name="TargetClassLevelId" class="form-control w-auto" required>
                        @foreach (var cls in classes) { <option value="@cls.Id">@cls.Name</option> }
                    </select>
                    <select name="TargetSectionId" class="form-control w-auto" required>
                        @foreach (var cls in classes)
                        {
                            foreach (var sec in cls.Sections.OrderBy(s => s.Name))
                            {
                                <option value="@sec.Id">@cls.Name - Section @sec.Name</option>
                            }
                        }
                    </select>
                    <button class="btn btn-primary" type="submit">Promote Selected</button>
                </div>
            </div>
            <div class="panel-body-nopad">
                <table class="data-table">
                    <thead><tr><th><input type="checkbox" onclick="document.querySelectorAll('.student-check').forEach(x => x.checked = this.checked)" /></th><th>ID</th><th>Name</th><th>Class</th><th>Section</th><th></th></tr></thead>
                    <tbody>
                    @foreach (var student in Model)
                    {
                        <tr>
                            <td><input class="student-check" type="checkbox" name="StudentIds" value="@student.Id" /></td>
                            <td>@student.StudentId</td>
                            <td>@student.Name</td>
                            <td>@student.ClassSection.ClassLevel.Name</td>
                            <td>@student.ClassSection.Name</td>
                            <td class="text-right"><a asp-action="StudentProfile" asp-route-id="@student.Id" class="btn btn-secondary">Profile</a></td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>
    </form>
</div>
