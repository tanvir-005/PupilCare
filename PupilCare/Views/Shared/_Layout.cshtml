<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - PupilCare</title>
    <!-- Google Fonts: Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="icon" type="image/png" href="~/icon.png">
</head>
<body>
    <header class="app-header">
        <div class="container header-container">
            @await Component.InvokeAsync("SystemInfo", new { part = "LogoOnly" })
            <nav class="main-nav">
                <ul class="nav-list">
                    <li class="nav-item">
                        <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                    </li>
                    <li class="nav-item">
                        <partial name="_LoginPartial" />
                    </li>
                </ul>
            </nav>
        </div>
    </header>

    <main role="main" class="main-content">
        <div class="container">
            @RenderBody()
        </div>
    </main>

    <footer class="app-footer detailed-footer">
        <div class="container">
            <div class="footer-grid">
                <!-- Left Side -->
                <div class="footer-left">
                    <div class="footer-support">
                        <h4 class="footer-heading">Need Guidance?</h4>
                        <p class="footer-text">Drop us your thoughts and get a response from our support team.</p>
                        <form asp-controller="Home" asp-action="SubmitContact" method="POST" class="support-form">
                            @Html.AntiForgeryToken()
                            <div class="form-group">
                                <input type="email" name="email" class="form-control" placeholder="Your email" required>
                            </div>
                            <div class="form-group">
                                <textarea name="message" class="form-control" rows="3" placeholder="Your message" required></textarea>
                            </div>
                            <button type="submit" class="btn btn-primary btn-block">Submit</button>
                        </form>
                    </div>
                    
                    <div class="footer-branding mt-4">
                        @await Component.InvokeAsync("SystemInfo", new { part = "Branding" })
                        @await Component.InvokeAsync("SystemInfo", new { part = "Contact" })
                        @await Component.InvokeAsync("SystemInfo", new { part = "Social" })
                    </div>
                </div>

                <!-- Right Side -->
                <div class="footer-right">
                    <div class="footer-widget">
                        <h4 class="footer-heading">Office Address</h4>
                        @await Component.InvokeAsync("SystemInfo", new { part = "Location" })
                    </div>
                    
                    <div class="footer-widget">
                        <h4 class="footer-heading">Our Certifications</h4>
                        @await Component.InvokeAsync("SystemInfo", new { part = "Certification" })
                    </div>
                    
                    <div class="footer-widget">
                        <h4 class="footer-heading">Quick Links</h4>
                        <ul class="footer-list footer-links">
                            <li><a asp-controller="Home" asp-action="About">About</a></li>
                            <li><a asp-controller="Home" asp-action="Services">Services</a></li>
                            <li><a asp-controller="Home" asp-action="Career">Career</a></li>
                            <li><a asp-controller="Home" asp-action="Partners">Partners</a></li>
                            <li><a asp-controller="Home" asp-action="PrivacyPolicy">Privacy Policy</a></li>
                            <li><a asp-controller="Home" asp-action="TermsOfService">Terms of Service</a></li>
                        </ul>
                    </div>
                </div>
            </div>
            
            <div class="footer-bottom">
                &copy; 2026 - PupilCare. All rights reserved.
            </div>
        </div>
    </footer>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
