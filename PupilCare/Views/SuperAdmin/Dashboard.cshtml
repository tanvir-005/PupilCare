@model IEnumerable<PupilCare.Models.School>
@{
    ViewData["Title"] = "Super Admin Dashboard";
}

<div class="dashboard-container">
    <div class="dashboard-header">
        <h2>@ViewData["Title"]</h2>
    </div>

    <div class="dashboard-layout">
        <!-- Left Side: Summary Cards -->
        <div class="dashboard-sidebar">
            <div class="stat-card stat-primary">
                <div class="stat-content">
                    <h6 class="stat-title">Total Schools</h6>
                    <h2 class="stat-value">@ViewBag.TotalSchools</h2>
                </div>
            </div>
            <div class="stat-card stat-success">
                <div class="stat-content">
                    <h6 class="stat-title">Approved</h6>
                    <h2 class="stat-value">@ViewBag.ApprovedSchools</h2>
                </div>
            </div>
            <div class="stat-card stat-warning">
                <div class="stat-content">
                    <h6 class="stat-title">Pending</h6>
                    <h2 class="stat-value">@ViewBag.PendingSchools</h2>
                </div>
            </div>
            <div class="stat-card stat-info">
                <div class="stat-content">
                    <h6 class="stat-title">Active Sub</h6>
                    <h2 class="stat-value">@ViewBag.ActiveSubscriptions</h2>
                </div>
            </div>
        </div>

        <!-- Right Side: Schools Table -->
        <div class="dashboard-main">
            <div class="panel">
                <div class="panel-header">
                    <h5 class="panel-title">All Schools</h5>
                    <div class="panel-actions">
                        <a asp-action="Dashboard" class="btn btn-secondary">Manage Schools</a>
                        <a asp-action="SubscriptionPlans" class="btn btn-primary">Manage Plans</a>
                    </div>
                </div>
                <div class="panel-body">
                    <div class="table-container">
                        <table class="data-table">
                            <thead>
                                <tr>
                                    <th class="col-school">School Name</th>
                                    <th>Status</th>
                                    <th>Subscription</th>
                                    <th class="text-right">Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model != null && Model.Any())
                                {
                                    @foreach(var school in Model)
                                    {
                                        <tr class="clickable-row" onclick="window.location.href='@Url.Action("SchoolDetails", new { id = school.Id })'">
                                            <td class="school-name">@school.Name</td>
                                            <td>
                                                @if (school.IsApproved) { <span class="status-badge status-approved">Approved</span> }
                                                else { <span class="status-badge status-pending">Pending</span> }
                                            </td>
                                            <td>
                                                @if (school.SubscriptionExpiry.HasValue && school.SubscriptionExpiry > DateTime.UtcNow)
                                                {
                                                    <span class="sub-status sub-active">Active (@((school.SubscriptionExpiry.Value - DateTime.UtcNow).Days) days)</span>
                                                }
                                                else
                                                {
                                                    <span class="sub-status sub-expired">Expired/None</span>
                                                }
                                            </td>
                                            <td class="text-right">
                                                <a asp-action="SchoolDetails" asp-route-id="@school.Id" class="btn btn-secondary" onclick="event.stopPropagation();">Details &rarr;</a>
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="4" class="empty-state">No schools found.</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
