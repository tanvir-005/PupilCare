@model PupilCare.Models.School
@{
    ViewData["Title"] = $"School Details: {Model.Name}";
    var adminUsers = ViewBag.AdminUsers as List<PupilCare.Models.ApplicationUser>;
    var teacherUsers = ViewBag.TeacherUsers as List<PupilCare.Models.ApplicationUser>;
}

<div class="dashboard-container">
    <div class="dashboard-header split-header">
        <h2>@Model.Name</h2>
        <div class="header-actions">
            @if (!Model.IsApproved)
            {
                <form asp-action="ApproveSchool" asp-route-id="@Model.Id" method="post" style="display:inline;">
                    <button type="submit" class="btn btn-success">Approve School</button>
                </form>
            }
            else
            {
                <form asp-action="RejectSchool" asp-route-id="@Model.Id" method="post" style="display:inline;">
                    <button type="submit" class="btn btn-warning">Revoke Approval</button>
                </form>
            }
            <a asp-action="Dashboard" class="btn btn-secondary">Back to Dashboard</a>
        </div>
    </div>

    <div class="details-grid">
        <div class="panel">
            <div class="panel-header">
                <h5 class="panel-title">General Information</h5>
            </div>
            <div class="panel-body">
                <table class="info-table">
                    <tr><th style="width: 30%">EIIN:</th><td>@(Model.EIIN ?? "N/A")</td></tr>
                    <tr><th>Address:</th><td>@(Model.Address ?? "N/A")</td></tr>
                    <tr><th>Status:</th>
                        <td>
                            @if (Model.IsApproved) { <span class="status-badge status-approved">Approved</span> }
                            else { <span class="status-badge status-pending">Pending</span> }
                        </td>
                    </tr>
                    <tr><th>Subscription:</th>
                        <td>
                            @if (Model.SubscriptionExpiry.HasValue && Model.SubscriptionExpiry > DateTime.UtcNow)
                            {
                                <span class="sub-status sub-active">Active until @Model.SubscriptionExpiry.Value.ToString("dd MMM yyyy")</span>
                            }
                            else
                            {
                                <span class="sub-status sub-expired">Expired or None</span>
                            }
                        </td>
                    </tr>
                </table>
            </div>
        </div>

        <div class="panel">
            <div class="panel-header">
                <h5 class="panel-title">Administrators</h5>
            </div>
            <div class="panel-body panel-body-nopad">
                <ul class="list-view">
                    @if (adminUsers != null && adminUsers.Any())
                    {
                        foreach (var admin in adminUsers)
                        {
                            <li class="list-item">
                                <strong>@admin.FullName</strong><br/>
                                <small class="text-muted">@admin.Email | @(admin.Designation ?? "Admin")</small>
                            </li>
                        }
                    }
                    else
                    {
                        <li class="list-item text-muted">No administrators found.</li>
                    }
                </ul>
            </div>
        </div>
    </div>

    <div class="panel form-panel mt-4">
        <div class="panel-header">
            <h5 class="panel-title">Grant Subscription</h5>
        </div>
        <div class="panel-body">
            <form asp-action="GrantSubscription" method="post" class="inline-form">
                <input type="hidden" name="schoolId" value="@Model.Id" />
                <div class="form-group inline-group">
                    <label for="months">Extend Subscription By (Months):</label>
                    <input type="number" name="months" id="months" class="form-control w-auto" value="1" min="1" max="60" required />
                </div>
                <button type="submit" class="btn btn-primary">Grant Access</button>
            </form>
        </div>
    </div>
    
    <div class="panel panel-danger mt-4">
        <div class="panel-header danger-header">
            <h5 class="panel-title">Danger Zone</h5>
        </div>
        <div class="panel-body">
            <p class="text-danger mb-4">Deleting a school is permanent and will remove all associated users, classes, students, and records.</p>
            <form asp-action="DeleteSchool" asp-route-id="@Model.Id" method="post" onsubmit="return confirm('Are you absolutely sure you want to delete this school and all its data? This action cannot be undone.');">
                <button type="submit" class="btn btn-danger">Delete School</button>
            </form>
        </div>
    </div>
</div>
