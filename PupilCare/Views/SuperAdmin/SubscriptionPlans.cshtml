@model IEnumerable<PupilCare.Models.SubscriptionPlan>
@{
    ViewData["Title"] = "Manage Subscription Plans";
}

<div class="dashboard-container">
    <div class="dashboard-header split-header">
        <h2>@ViewData["Title"]</h2>
        <a asp-action="CreatePlan" class="btn btn-primary">Create New Plan</a>
    </div>

    <div class="plans-grid">
        @foreach (var plan in Model)
        {
            <div class="plan-card @(plan.IsActive ? "plan-active" : "plan-inactive")">
                <div class="plan-header">
                    <h5 class="plan-title">@plan.Name</h5>
                    @if (plan.IsActive)
                    {
                        <span class="status-badge status-approved">Active</span>
                    }
                    else
                    {
                        <span class="status-badge status-inactive">Inactive</span>
                    }
                </div>
                <div class="plan-body">
                    <h2 class="plan-price">৳@plan.Price.ToString("0.00")</h2>
                    <p class="plan-duration">
                        Duration: @plan.DurationDays Days @(plan.DurationMinutes > 0 ? $" {plan.DurationMinutes} Mins" : "")
                    </p>
                    <p class="plan-desc">@plan.Description</p>
                </div>
                <div class="plan-footer">
                    <a asp-action="EditPlan" asp-route-id="@plan.Id" class="btn btn-secondary">Edit</a>
                    <form asp-action="DeletePlan" asp-route-id="@plan.Id" method="post" onsubmit="return confirm('Are you sure you want to delete this plan?');">
                        <button type="submit" class="btn btn-danger">Delete</button>
                    </form>
                </div>
            </div>
        }
    </div>
</div>
