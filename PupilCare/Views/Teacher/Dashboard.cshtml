@model IEnumerable<PupilCare.Models.TeacherAssignment>
@{
    ViewData["Title"] = "Teacher Dashboard";
    var classTeacherFor = ViewBag.ClassTeacherFor as List<PupilCare.Models.ClassLevel> ?? new();
}

<div class="dashboard-container">
    <div class="dashboard-header split-header">
        <h2>Teacher Dashboard</h2>
        <a asp-controller="Insights" asp-action="Index" class="btn btn-secondary">AI Insights</a>
    </div>

    @if (classTeacherFor.Any())
    {
        <div class="panel">
            <div class="panel-header"><h5 class="panel-title">Class Teacher Access</h5></div>
            <div class="panel-body">
                @foreach (var cls in classTeacherFor)
                {
                    <span class="status-badge status-approved">@cls.Name</span>
                }
            </div>
        </div>
    }

    <div class="panel">
        <div class="panel-header"><h5 class="panel-title">Assigned Section Subjects</h5></div>
        <div class="panel-body-nopad">
            <table class="data-table">
                <thead><tr><th>Class</th><th>Section</th><th>Subject</th><th></th></tr></thead>
                <tbody>
                @foreach (var assignment in Model)
                {
                    <tr>
                        <td>@assignment.ClassSection.ClassLevel.Name</td>
                        <td>@assignment.ClassSection.Name</td>
                        <td>@assignment.Subject.Name</td>
                        <td class="text-right"><a asp-action="SectionSubject" asp-route-sectionId="@assignment.ClassSectionId" asp-route-subjectId="@assignment.SubjectId" class="btn btn-primary">Open</a></td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>
